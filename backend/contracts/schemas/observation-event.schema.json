{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jasy-jatere/contracts/observation-event/v1",
  "title": "ObservationEvent",
  "type": "object",
  "required": [
    "id",
    "cameraId",
    "timestamp",
    "kind",
    "source"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "cameraId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": [
        "perception",
        "onvif-events",
        "manual"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "motion",
        "detection",
        "state-change"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "motion": {
      "type": "object",
      "properties": {
        "active": {
          "type": "boolean"
        },
        "score": {
          "type": "number",
          "minimum": 0
        },
        "healthy": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "detections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "confidence"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
