{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jasy-jatere/contracts/recording-catalog-upsert-request/v1",
  "title": "RecordingCatalogUpsertRequest",
  "type": "object",
  "required": [
    "filename",
    "camera_id",
    "event_time",
    "status"
  ],
  "properties": {
    "filename": {
      "type": "string",
      "minLength": 1
    },
    "camera_id": {
      "type": "string",
      "minLength": 1
    },
    "camera_name": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "recording_started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "recording_completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "duration_seconds": {
      "type": [
        "number",
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "recording_in_progress",
        "ready",
        "failed",
        "deleted"
      ]
    },
    "thumbnail": {
      "type": [
        "string",
        "null"
      ]
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
