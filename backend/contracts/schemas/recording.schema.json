{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jasy-jatere/contracts/recording/v1",
  "title": "Recording",
  "type": "object",
  "required": [
    "id",
    "cameraId",
    "startedAt",
    "status",
    "assets"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "cameraId": {
      "type": "string",
      "minLength": 1
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "recording",
        "completed",
        "failed",
        "deleted"
      ]
    },
    "eventType": {
      "type": "string"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "video",
              "thumbnail",
              "metadata",
              "log"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
