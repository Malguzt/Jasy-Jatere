{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jasy-jatere/contracts/map-manual-request/v1",
  "title": "MapManualRequest",
  "type": "object",
  "required": [
    "cameras"
  ],
  "properties": {
    "promote": {
      "type": "boolean"
    },
    "qualityScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "cameras": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": [
              "string",
              "number"
            ]
          },
          "cameraId": {
            "type": [
              "string",
              "number"
            ]
          },
          "label": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "yawDeg": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "cameraId": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
