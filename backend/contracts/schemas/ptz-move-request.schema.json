{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jasy-jatere/contracts/ptz-move-request/v1",
  "title": "PtzMoveRequest",
  "type": "object",
  "required": [
    "url",
    "direction"
  ],
  "properties": {
    "url": {
      "type": "string",
      "minLength": 1
    },
    "user": {
      "type": "string"
    },
    "pass": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": [
        "up",
        "down",
        "left",
        "right",
        "zoom-in",
        "zoom-out"
      ]
    }
  },
  "additionalProperties": false
}
