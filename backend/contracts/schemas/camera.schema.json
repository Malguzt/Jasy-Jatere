{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jasy-jatere/contracts/camera/v1",
  "title": "Camera",
  "type": "object",
  "required": [
    "id",
    "name",
    "status",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "degraded",
        "error"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "single",
        "combined"
      ],
      "default": "single"
    },
    "siteId": {
      "type": [
        "string",
        "null"
      ]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
