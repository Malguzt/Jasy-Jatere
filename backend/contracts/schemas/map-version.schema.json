{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jasy-jatere/contracts/map-version/v1",
  "title": "MapVersion",
  "type": "object",
  "required": [
    "schemaVersion",
    "mapId",
    "createdAt",
    "quality",
    "cameras",
    "objects"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "mapId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0
    },
    "sourceJobId": {
      "type": [
        "string",
        "null"
      ]
    },
    "quality": {
      "type": "object",
      "required": [
        "mode",
        "score"
      ],
      "properties": {
        "mode": {
          "type": "string"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "planUsed": {
          "type": "string"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "cameras": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "x",
          "y"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "yawDeg": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "category",
          "x",
          "y"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "confidence": {
            "type": "number"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
