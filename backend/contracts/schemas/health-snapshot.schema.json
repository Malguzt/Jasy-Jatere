{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jasy-jatere/contracts/health-snapshot/v1",
  "title": "HealthSnapshot",
  "type": "object",
  "required": [
    "snapshotId",
    "capturedAt",
    "summary",
    "cameras"
  ],
  "properties": {
    "snapshotId": {
      "type": "string",
      "minLength": 1
    },
    "capturedAt": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "type": "object",
      "required": [
        "cameras",
        "online",
        "offline"
      ],
      "properties": {
        "cameras": {
          "type": "integer",
          "minimum": 0
        },
        "online": {
          "type": "integer",
          "minimum": 0
        },
        "offline": {
          "type": "integer",
          "minimum": 0
        },
        "degraded": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "cameras": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "availability"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "availability": {
            "type": "string",
            "enum": [
              "up",
              "degraded",
              "down",
              "unknown"
            ]
          },
          "availabilityScore": {
            "type": "number"
          },
          "checkedAt": {
            "type": "integer"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "availability"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "availability": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
